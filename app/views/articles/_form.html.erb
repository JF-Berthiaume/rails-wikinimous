<%= form_with model: article do |f| %>
  <div class="mb-3">
    <%= f.label :title, "Titre de l'article", class: "form-label" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :content, "Contenu", class: "form-label" %>
    <%= f.text_area :content, class: "form-control", rows: 10 %>
  </div>

  <%= f.submit "Enregistrer", class: "btn btn-success" %>
  <%= link_to "Annuler", articles_path, class: "btn btn-link text-secondary" %>
<% end %>
